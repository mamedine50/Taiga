# Portail web Taïga — variables d'environnement
# Copiez ce fichier en `.env.local` et renseignez vos valeurs (NE JAMAIS commiter .env.local).
# Supabase : Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service (serveur uniquement — webhook Stripe, facturation). NE JAMAIS exposer côté client.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (mode test) — Dashboard Stripe → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Fourni par « stripe listen » en dev, ou par le webhook du dashboard en prod
STRIPE_WEBHOOK_SECRET=

# Numéros de taxes de l'entreprise (affichés sur les factures)
TAIGA_GST_NUMBER=
TAIGA_QST_NUMBER=
